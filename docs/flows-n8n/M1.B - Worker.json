    {
      "parameters": {
        "jsCode": "// PARSER V11 - Detección Inteligente (Mensajes vs Ecos)\nconst row = items[0].json;\nif (!row) return [];\n\nlet payload;\ntry {\n    payload = typeof row.raw_payload === 'string' ? JSON.parse(row.raw_payload) : row.raw_payload;\n} catch (e) {\n    // Si el JSON está roto, lo marcamos como IGNORADO para sacarlo de la cola y no trabar el flujo\n    return { json: { is_valid: false, status_to_save: 'IGNORED', error: \"JSON Parse Error\", db_id: row.id } };\n}\n\n// Navegación segura por el objeto de Meta\nlet entry = null;\nif (payload.entry) {\n    entry = payload.entry[0];\n} else if (payload.body && payload.body.entry) {\n    entry = payload.body.entry[0];\n}\n\nconst changes = entry ? entry.changes[0] : null;\nconst value = changes ? changes.value : null;\n\n// --- FILTRO DE CLASIFICACIÓN ---\n\n// 1. DETECCIÓN DE ECOS (Statuses: sent, delivered, read)\n// Si esto existe, NO es un mensaje de usuario. Es basura técnica.\nif (value && value.statuses) {\n    return {\n        json: {\n            is_valid: false,\n            db_id: row.id,\n            status_to_save: 'IGNORED', // <--- ESTO LIMPIA TU COLA PENDING\n            reason: \"Meta Receipt (Eco)\"\n        }\n    };\n}\n\n// 2. DETECCIÓN DE MENSAJES REALES\nconst message = value && value.messages ? value.messages[0] : null;\n\nif (!message) {\n  // Si no es status ni mensaje, es un evento desconocido. Lo ignoramos.\n  return { json: { is_valid: false, status_to_save: 'IGNORED', error: \"No message found\", db_id: row.id } };\n}\n\n// 3. EXTRACCIÓN DE DATOS (Solo si llegamos aquí es un mensaje real)\nconst contact = value && value.contacts ? value.contacts[0] : null;\n\n// Normalización de tipos\nlet finalType = message.type;\nif (finalType === 'voice') finalType = 'audio';\n\n// Retorno ÉXITO -> Esto activará al M2\nreturn {\n  json: {\n    is_valid: true,\n    db_id: row.id,\n    status_to_save: 'NORMALIZED', // <--- ESTO ES ORO PARA EL M2\n    wa_id: contact ? contact.wa_id : null,\n    name: contact && contact.profile ? contact.profile.name : \"Desconocido\",\n    msg_type: finalType,\n    msg_body: message.text ? message.text.body : null,\n    media_id: message[message.type] ? message[message.type].id : null,\n    timestamp: message.timestamp,\n    // Estructura lista para guardar en processed_json si lo necesitas\n    processing_results: {\n        contact_phone: contact ? contact.wa_id : null,\n        final_text: message.text ? message.text.body : null,\n        cw_contact_id: null // Se llenará después\n    }\n  }\n};"
      },
