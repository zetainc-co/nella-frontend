    {
      "parameters": {
        "jsCode": "// 1. Recuperamos los datos del presente (Viene de BUSCAR o de CREAR)\nconst cwInput = $input.all()[0].json;\n\n// 2. Recuperamos los datos del pasado (Nodo \"Extraer Datos\")\nconst wa = $items(\"Extraer Datos\")[0].json;\n\n// --- LÓGICA DE DETECCIÓN INTELIGENTE ---\nlet finalConvId;\nlet finalContactId;\nlet finalPhone;\n\n// CASO A: Viene del BUSCADOR (Es una lista dentro de payload)\n// Verificamos si existe 'payload' y si es una lista\nif (cwInput.data && cwInput.data.payload && Array.isArray(cwInput.data.payload)) {\n    finalConvId = cwInput.data.payload[0].id;\n    finalContactId = cwInput.data.payload[0].meta.sender.id;\n    finalPhone = cwInput.data.payload[0].meta.sender.phone_number;\n}\n// CASO B: Viene de CREAR (Es un objeto directo)\n// Verificamos si tiene un ID directo\nelse if (cwInput.id) {\n    finalConvId = cwInput.id;\n    finalContactId = cwInput.meta.sender.id;\n    finalPhone = cwInput.meta.sender.phone_number;\n}\n// CASO C: Fallback (Por si acaso)\nelse {\n    // Intentamos leerlo de la metadata si falló lo anterior\n    finalConvId = cwInput.payload ? cwInput.payload[0].id : null;\n}\n\nreturn {\n  json: {\n    // --- CONTEXTO CHATWOOT (Normalizado) ---\n    cw_conversation_id: finalConvId,\n    cw_contact_id: finalContactId,\n    cw_phone: finalPhone,\n\n    // --- CONTEXTO DEL MENSAJE (Original) ---\n    msg_type: wa.msg_type,\n    media_id: wa.media_id,\n    msg_body: wa.msg_body,\n    wa_id: wa.wa_id\n  }\n};"
      },
