      "parameters": {
        "jsCode": "// 1. Recuperamos la respuesta de la IA (Vision)\nconst visionInput = $input.all()[0].json;\n\n// 2. RECUPERAMOS EL ARCHIVO PERDIDO 🕵️‍♂️\n// Buscamos la imagen en el nodo anterior a la Vision (tu Sub-Router)\n// Si cambiaste el nombre del nodo \"Sub-Router Media\", ajustalo aquí:\nconst binaryInput = $('Sub-Router Media').first().binary; \n\n// Navegamos hasta el texto de OpenAI\nconst content = visionInput.output?.[0]?.content?.[0]?.text || \"\";\n\nlet analysis;\ntry {\n    const clean = content.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n    analysis = JSON.parse(clean);\n} catch (e) {\n    analysis = { tag: \"RUIDO\", summary: \"Error de análisis\" };\n}\n\nreturn {\n    json: {\n        ...visionInput,\n        vision_tag: analysis.tag,\n        vision_desc: analysis.summary\n    },\n    // Aquí entregamos la imagen que rescatamos del pasado\n    binary: binaryInput \n};"
