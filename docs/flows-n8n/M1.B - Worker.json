      "parameters": {
        "jsCode": "const input = $input.all()[0].json;\n\n// Si es un array (vino de búsqueda), tomamos el primero. Si es objeto (vino de crear), lo usamos directo.\nconst contactData = Array.isArray(input.payload) ? input.payload[0] : input.payload.contact; \n// Nota: A veces Crear devuelve { payload: { contact: {...} } } verifica el output.\n// Si Chatwoot devuelve directo el objeto en crear, usa: input.payload;\n\nreturn {\n  json: {\n    meta: {\n        sender: {\n            id: contactData.id || contactData.payload.contact.id, // Ajuste de seguridad\n            phone_number: contactData.phone_number,\n            name: contactData.name\n        }\n    }\n  }\n};"
