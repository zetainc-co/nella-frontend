    {
      "parameters": {
        "jsCode": "// 1. Traemos el Contexto Global\nconst context = $('Fijar Contexto').first().json;\n\n// 2. Variables por defecto\nlet finalBody = \"\";\nlet processingSource = \"unknown\";\nlet isSales = false;\nlet forceHandoff = false; // Nueva variable de control interno\n\n// 3. LÓGICA BLINDADA\n\n// CASO A: AUDIO 🎤\nif (context.msg_type === 'audio') {\n    try {\n        finalBody = $('Whisper').last().json.text;\n        processingSource = \"audio_transcription\";\n    } catch (e) {\n        finalBody = \"(Audio sin transcripción disponible)\";\n    }\n}\n\n// CASO B: IMAGEN 📸 (Tu lógica de Venta vs Ruido)\nelse if (context.msg_type === 'image') {\n    try {\n        // Buscamos la respuesta del nodo Code anterior o del IF\n        // Nota: Asegúrate de leer del nodo correcto según tu flujo\n        const visionData = $('Clasificar Imagen').last().json; \n        \n        if (visionData.vision_tag === 'VENTA') {\n             finalBody = \"📸 VENTA DETECTADA: \" + (visionData.vision_desc || \"Comprobante/Documento\");\n             isSales = true;\n             forceHandoff = true; // ¡Venta = Humano!\n        } else {\n             finalBody = \"🖼️ Imagen (Ruido): \" + (visionData.vision_desc || \"Meme/Irrelevante\");\n        }\n        processingSource = \"image_vision\";\n    } catch (e) {\n        finalBody = \"(Imagen sin análisis)\";\n    }\n}\n\n// CASO C: DOCUMENTOS Y VIDEO 📂🎥 (Ajuste Solicitado)\nelse if (context.msg_type === 'document' || context.msg_type === 'video') {\n    // Como ya pasaron por el nodo \"CW: Subir Archivo\", aquí solo registramos el hecho\n    const tipo = context.msg_type === 'video' ? '🎥 Video' : 'fyp Documento';\n    finalBody = `${tipo} recibido y transferido a agente.`;\n    \n    processingSource = \"media_handoff\";\n    forceHandoff = true; // Forzamos el handoff aquí también para la DB\n}\n\n// CASO D: TEXTO 📝\nelse if (context.msg_type === 'text') {\n    finalBody = context.msg_body; \n    processingSource = \"text_message\";\n}\n\n// CASO E: OTROS (Ubicación, Contactos, etc.)\nelse {\n    finalBody = \"Archivo: \" + context.msg_type;\n    processingSource = \"media_file\";\n    // Opcional: ¿Quieres handoff también para ubicaciones? Si sí, descomenta:\n    // forceHandoff = true; \n}\n\n// 4. Salida Estandarizada\nreturn {\n    json: {\n        process_status: 'PROCESSED',\n        final_text: finalBody,\n        source: processingSource,\n        is_sales_lead: isSales,\n        cw_conversation_id: context.cw_conversation_id,\n        cw_contact_id: context.cw_contact_id,\n        wa_phone: context.cw_phone,\n        // El handoff se activa si es venta, si es video/doc, o si forzamos manualmente\n        handoff_required: (forceHandoff || isSales)\n    }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
