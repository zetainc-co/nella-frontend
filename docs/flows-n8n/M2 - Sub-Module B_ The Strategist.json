    {
      "parameters": {
        "jsCode": "// 1. Obtener la data original\nconst input = $input.item.json;\n\n// 2. BUSCADOR DE TESOROS (Adaptado a tu estructura exacta)\nlet rawText = null;\n\n// CASO PRIORITARIO: La estructura que salió en tu error (Output Array -> Content Array)\nif (Array.isArray(input.output) && input.output[0]?.content?.[0]?.text) {\n  rawText = input.output[0].content[0].text;\n}\n// CASO B: Estructura alternativa (Content como array directo)\nelse if (Array.isArray(input.content) && input.content[0]?.text) {\n  rawText = input.content[0].text;\n}\n// CASO C: Estructura estándar OpenAI/LangChain (Message object)\nelse if (input.message?.content) {\n  rawText = input.message.content;\n}\n// CASO D: Texto plano directo\nelse if (typeof input.output === 'string') {\n  rawText = input.output;\n}\n\n// Validación de seguridad final\nif (!rawText) {\n  // Si falla, devolvemos el error con la estructura para seguir depurando si fuera necesario\n  return { json: { error: \"No text found (Intento 3)\", structure_received: Object.keys(input) } };\n}\n\n// 3. LIMPIEZA Y PARSEO\n// Quitamos markdown ```json ... ``` y espacios\nconst cleanString = rawText\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\ntry {\n  const finalObj = JSON.parse(cleanString);\n  return { json: finalObj };\n} catch (e) {\n  return {\n    json: {\n      error: \"Parsing Error\",\n      raw_text: rawText\n    }\n  };\n}"
      },
