    {
      "parameters": {
        "jsCode": "// Obtener el nombre completo si existe, o \"Cliente\" si no.\nconst fullName = $('Start').item.json.name || \"Cliente\";\n\n// Dividir por espacios y tomar la primera parte\n// \"Gio Gómez\" -> [\"Gio\", \"Gómez\"] -> toma \"Gio\"\nconst firstName = fullName.trim().split(' ')[0];\n// Asegurar primera letra mayúscula\nconst formattedName = firstName.charAt(0).toUpperCase() + firstName.slice(1).toLowerCase();\n\nreturn { json: { firstName: formattedName } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        160,
        0
      ],
      "id": "ca456e36-da3a-47a7-98d0-692fb694e132",
