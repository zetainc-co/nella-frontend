    {
      "parameters": {
        "jsCode": "// Buscamos el teléfono de forma profunda en el JSON\nconst buscarTelefono = (obj) => {\n    for (let k in obj) {\n        if (k === 'phone_number' && typeof obj[k] === 'string' && obj[k].length > 5) return obj[k];\n        if (obj[k] !== null && typeof obj[k] === 'object') {\n            let res = buscarTelefono(obj[k]);\n            if (res) return res;\n        }\n    }\n    return null;\n};\n\nconst rawPhone = buscarTelefono($input.item.json.body) || \"\";\n\nreturn {\n    phone: rawPhone.replace(/\\D/g, '') // Deja solo los números\n};"
      },
