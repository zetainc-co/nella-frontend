      "parameters": {
        "jsCode": "// Normalización de datos\nconst payload = $input.item.json.body;\n\n// Obtener teléfono (Buscamos en meta.sender o contact_inbox)\nlet phoneRaw = '';\nif (payload.conversation && payload.conversation.meta && payload.conversation.meta.sender) {\n  phoneRaw = payload.conversation.meta.sender.phone_number;\n} else if (payload.conversation && payload.conversation.contact_inbox && payload.conversation.contact_inbox.contact) {\n  phoneRaw = payload.conversation.contact_inbox.contact.phone_number;\n}\n\n// Limpieza E.164 (Solo números)\nconst cleanPhone = phoneRaw ? phoneRaw.replace(/\\D/g, '') : '';\n\nreturn {\n  phone: cleanPhone,\n  text: payload.content,\n  cw_conversation_id: payload.conversation.id,\n  sender_name: payload.sender ? payload.sender.name : 'Agente',\n  raw_body: payload\n};"
      },
